<?xml version="1.0" encoding="UTF-8"?>
<tomee>
	<!-- see http://tomee.apache.org/containers-and-resources.html -->

	<!-- activate next line to be able to deploy applications in apps -->
	<Deployments dir="apps" />

	<Resource id="tedrosDataSource" type="DataSource">
		JdbcDriver org.h2.Driver
		JdbcUrl jdbc:h2:tcp://localhost/~/.tedrosData/h2/db;INIT=runscript from '~/.tedrosData/init.sql';
		UserName tdrs
		Password xpto
		JtaManaged true
		PoolPreparedStatements true
		DefaultAutoCommit true
	</Resource>
	

    <Resource id="TedrosJmsResourceAdapter" type="ActiveMQResourceAdapter">
        BrokerXmlConfig  = broker:(tcp://localhost:61616)
        ServerUrl = tcp://localhost:61616        
    </Resource>

    <Resource id="jms/TedrosJmsConnectionFactory" type="jakarta.jms.ConnectionFactory">
        ResourceAdapter = TedrosJmsResourceAdapter
    </Resource>

    <Container id="TedrosJmsMdbContainer" ctype="MESSAGE">
        ResourceAdapter = TedrosJmsResourceAdapter
    </Container>

    <Resource id="NotifyQueue" type="jakarta.jms.Queue"/> 

</tomee>
